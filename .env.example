# Gemini API Key — IA légère (chat quotidien, relances)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Claude API Key — IA avancée (analyse stratégique, rapports, scoring)
VITE_CLAUDE_API_KEY=your_claude_api_key_here

# CopilotKit — Interface agent IA (chat, actions, données en lecture)
VITE_COPILOTKIT_PUBLIC_API_KEY=your_copilotkit_public_key_here

# Supabase (optional — defaults are provided in code)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
